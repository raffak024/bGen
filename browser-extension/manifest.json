{
  "manifest_version": 3,
  "name": "bGen AI Text Editor",
  "version": "1.0.0",
  "description": "Intelligenter AI Text-Editor für jedes Textfeld im Web. Pro Version mit bGen Integration.",
  "author": "bGen Team",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "bGen AI Text Editor"
  },

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "http://localhost:3001/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "css": ["styles/content.css"],
      "run_at": "document_end"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["styles/toolbar.css", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
